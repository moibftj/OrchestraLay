{
  "name": "orchestralay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "orchestralay": "./dist/cli/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "chart.js": "^4.4.0",
    "diff": "^7.0.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "openai": "^4.85.0",
    "pg": "^8.13.0",
    "pg-boss": "^10.1.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.0",
    "wouter": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm-run-all build:client build:server build:cli",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "start": "node dist/server/server/index.js",
    "check": "npm-run-all check:server check:client check:cli",
    "check:server": "tsc -p tsconfig.server.json --noEmit",
    "check:client": "tsc -p tsconfig.client.json --noEmit",
    "check:cli": "tsc -p tsconfig.cli.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "cli": "tsx cli/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.90.5",
    "@trpc/client": "^11.7.1",
    "@trpc/react-query": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "diff": "^8.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "express": "^5.1.0",
    "openai": "^6.6.0",
    "pg": "^8.16.3",
    "pg-boss": "^10.4.2",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.0",
    "superjson": "^2.2.5",
    "wouter": "^3.7.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.5",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}