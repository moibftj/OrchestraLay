{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@server/*": ["server/*"]
    },
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["server/**/*.ts", "src/**/*.ts", "src/**/*.tsx", "cli/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
